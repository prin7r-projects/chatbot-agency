# == Public URLs ==
# Public app URL used in NOWPayments redirects + IPN callback URLs.
NEXT_PUBLIC_APP_URL=https://chatbot-agency.prin7r.com
NEXT_PUBLIC_SITE_URL=https://chatbot-agency.prin7r.com

# == NOWPayments (Wave 2 + 3) ==
# Hosted invoice + IPN. Keys live only in the deploy host's /opt/prin7r-deploys/chatbot-agency/.env
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false

# == Database ==
# Postgres 16 + pgvector connection (Wave 3)
DATABASE_URL=postgresql://relayhouse:relayhouse_dev@localhost:5432/relayhouse

# == Redis ==
# Redis 7 connection (Wave 3 — BullMQ queues, caching)
REDIS_URL=redis://localhost:6379

# == Encryption ==
# AES-256-GCM key for encrypting channel tokens at rest (Wave 3)
INTEGRATION_KEY=

# == LLM Providers ==
# Primary: Z.ai GLM 5.1 Flash (Wave 3)
GLM_API_KEY=
# Fallback: Anthropic Haiku 4.5 (Wave 3)
ANTHROPIC_API_KEY=

# == Voice Transcription ==
# Self-hosted Whisper endpoint for voice note transcription (Wave 3)
WHISPER_ENDPOINT=

# == Admin ==
# Bearer token for admin endpoints (Wave 3). 90-day rotation.
ADMIN_API_KEY=

# == Dispatcher ==
# Telegram channel ID for dispatcher pings (Wave 3)
# Set to @relayhouse_dispatcher
DISPATCHER_TG_CHANNEL_ID=

# == Email ==
# Postmark server token for transactional email (Wave 3)
POSTMARK_SERVER_TOKEN=

# == Wasp App (apps/app) ==
# Wasp server URL (set by Wasp at build time)
WASP_SERVER_URL=http://localhost:3001
# Wasp web client URL
WASP_WEB_CLIENT_URL=http://localhost:3000

# == Forward-compat (not yet used) ==
# WalletConnect / Reown project
NEXT_PUBLIC_REOWN_PROJECT_ID=
# Plisio direct stablecoin
PLISIO_API_KEY=

# == Merchant settlement wallets (forward-compat) ==
MERCHANT_USDT_TRC20_ADDRESS=
MERCHANT_USDT_ERC20_ADDRESS=
MERCHANT_USDC_ERC20_ADDRESS=
MERCHANT_USDC_POLYGON_ADDRESS=
MERCHANT_USDT_BSC_ADDRESS=
